# Anaplan Audit History — environment variables
# Copy this file to .env and fill in the values.
# .env is gitignored and is read automatically at runtime.
#
# Only basic-auth credentials belong here. OAuth uses `oauthClientId`
# in settings.json (set for you by `anaplan-audit register`), and
# certificate auth uses the cert paths in settings.json.

# Basic auth credentials (used when authenticationMode = "basic")
ANAPLAN_AUDIT_BASIC_USERNAME=
ANAPLAN_AUDIT_BASIC_PASSWORD=
