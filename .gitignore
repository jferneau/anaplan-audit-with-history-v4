samples/
latest-run-log.txt
*_backup_*.db

# Markdown is local build context for Claude Code, not shipped to customers.
# Only the root README.md is published. (Excludes CLAUDE.md, the spec/handoff
# docs, docs/*.md, CONTRIBUTING.md, SECURITY.md, scratch findings, etc.)
*.md
!README.md

# Stale v3 documentation set — pending a dedicated v4 rewrite. The README is
# the single source of truth for v4 until these are refreshed.
docs/
